{
  "name": "АСУ СЦ Сервис Климат",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": true
    }
  },

  "forwardPorts": [5173, 8090, 5432, 6379, 15672],
  "portsAttributes": {
    "5173": { "label": "Фронтенд (React)", "onAutoForward": "openBrowser" },
    "8090": { "label": "Бэкенд API (Spring Boot)" },
    "15672": { "label": "RabbitMQ панель" }
  },

  "postCreateCommand": "npm install && echo '✅ npm готов. Запустите: bash scripts/start-dev.sh'",

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.vscode-xml",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
