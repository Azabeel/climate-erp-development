{
  "realm": "servisklimat",
  "enabled": true,
  "displayName": "Сервис Климат",
  "displayNameHtml": "<b>АСУ СЦ «Сервис Климат»</b>",
  "defaultLocale": "ru",
  "internationalizationEnabled": true,
  "supportedLocales": ["ru", "en"],
  "loginTheme": "keycloak",
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "ADMIN",      "description": "Системный администратор" },
      { "name": "MANAGER",    "description": "Руководитель СЦ" },
      { "name": "DISPATCHER", "description": "Диспетчер" },
      { "name": "ENGINEER",   "description": "Инженер" },
      { "name": "ACCOUNTANT", "description": "Бухгалтер" },
      { "name": "SALES",      "description": "Менеджер по продажам" },
      { "name": "VIEWER",     "description": "Только просмотр" }
    ]
  },
  "clients": [
    {
      "clientId": "servis-klimat-backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "sk-backend-secret",
      "bearerOnly": true,
      "publicClient": false
    },
    {
      "clientId": "servis-klimat-web",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:80/*"],
      "webOrigins": ["http://localhost:5173", "http://localhost:80"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "servis-klimat-mobile",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["servisklimat://callback"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@servisklimat.ru",
      "firstName": "Администратор",
      "lastName": "Системы",
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "realmRoles": ["ADMIN", "MANAGER"]
    },
    {
      "username": "dispatcher",
      "enabled": true,
      "email": "dispatcher@servisklimat.ru",
      "firstName": "Диспетчер",
      "lastName": "Тестовый",
      "credentials": [{ "type": "password", "value": "dispatcher123", "temporary": false }],
      "realmRoles": ["DISPATCHER"]
    },
    {
      "username": "engineer1",
      "enabled": true,
      "email": "engineer1@servisklimat.ru",
      "firstName": "Иван",
      "lastName": "Петров",
      "credentials": [{ "type": "password", "value": "engineer123", "temporary": false }],
      "realmRoles": ["ENGINEER"]
    }
  ],
  "passwordPolicy": "length(8)",
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 60
}
